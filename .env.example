# Copy this file to .env and set your values.
#
# Superuser login (ritesha) password: set ONLY in Streamlit secrets — see streamlit-secrets.example.toml
# and README (not in this file).

# Supabase (required for database)
# Get these from Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Or use SUPABASE_KEY if you prefer (service role key recommended for full access)
# SUPABASE_KEY=your-service-role-key

# Set to false only if you get SSL certificate errors (e.g. self-signed / corporate proxy)
# SUPABASE_VERIFY_SSL=false
